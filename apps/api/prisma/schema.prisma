generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 0. Authentication - 사용자
// ============================================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String   // MVP: 이메일 인증 (소셜 로그인은 Phase 2)
  name          String
  nickname      String   @unique
  profileImage  String?
  bio           String?  // 한줄 소개
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  bandMembers         BandMember[]
  organizationMembers OrganizationMember[]
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  managedVenues       Venue[]              @relation("VenueManager")
  createdPerformances Performance[]        @relation("PerformanceCreator")

  @@map("users")
}

// ============================================
// 1. Organization (동아리/연합) 관리
// ============================================

model Organization {
  id           String           @id @default(uuid())
  name         String
  type         OrganizationType
  description  String?
  profileImage String?
  coverImage   String?          // 커버 이미지 (기획서)
  school       String?          // 소속 학교 (대전 지역 플랫폼)
  region       String?          // 지역
  snsLinks     Json?            // { instagram: "...", youtube: "..." }
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Relations
  bands         Band[]
  members       OrganizationMember[]
  announcements Announcement[]

  @@index([type])
  @@index([school])
  @@map("organizations")
}

enum OrganizationType {
  UNIVERSITY_CLUB    // 대학 동아리
  BAND_UNION         // 밴드 연합
  INDIE_COLLECTIVE   // 인디 집단
  PLANNING_TEAM      // 기획팀/크루
  OTHER
}

model OrganizationMember {
  id             String        @id @default(uuid())
  organizationId String
  userId         String
  role           OrgMemberRole @default(MEMBER)
  joinedAt       DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

enum OrgMemberRole {
  ADMIN
  MEMBER
}

model Announcement {
  id             String   @id @default(uuid())
  organizationId String
  authorId       String
  title          String
  content        String
  isPinned       Boolean  @default(false) // 상단 고정
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt(sort: Desc)])
  @@map("announcements")
}

// ============================================
// 2. Band (밴드) 관리
// ============================================

model Band {
  id             String      @id @default(uuid())
  name           String
  genre          String[]    // ["Rock", "Indie", ...]
  description    String?
  profileImage   String?
  coverImage     String?     // 카드 커버 이미지 (DB_schema)
  snsLinks       Json?       // { instagram: "...", youtube: "...", soundcloud: "..." }
  status         BandStatus  @default(ACTIVE) // 기획서: 활동 상태
  inviteCode     String      @unique // DB_schema: 가입용 초대 코드
  organizationId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  members      BandMember[]
  performances PerformanceBand[]
  reservations Reservation[]

  @@index([organizationId])
  @@index([status])
  @@map("bands")
}

enum BandStatus {
  ACTIVE
  HIATUS
  DISBANDED
}

model BandMember {
  id       String         @id @default(uuid())
  bandId   String
  userId   String
  role     BandMemberRole @default(MEMBER)
  part     String?        // "Vocal", "Guitar", "Bass", "Drum", "Keyboard"
  joinedAt DateTime       @default(now())

  band Band @relation(fields: [bandId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bandId, userId])
  @@map("band_members")
}

enum BandMemberRole {
  ADMIN
  MEMBER
}

// ============================================
// 3. Performance (공연) 관리
// ============================================

model Performance {
  id          String            @id @default(uuid())
  title       String
  description String?
  date        DateTime          // 공연 날짜
  startTime   String?           // "19:00" (기획서)
  endTime     String?           // "22:00" (기획서)
  venueId     String?
  ticketPrice Int?              // 0 = 무료
  posterImage String?
  status      PerformanceStatus @default(UPCOMING)
  createdBy   String            // 등록자 (기획서: 누가 등록했는지 추적)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  venue   Venue?            @relation(fields: [venueId], references: [id], onDelete: SetNull)
  creator User              @relation("PerformanceCreator", fields: [createdBy], references: [id])
  bands   PerformanceBand[]

  @@index([date(sort: Desc)])
  @@index([status])
  @@index([venueId])
  @@map("performances")
}

enum PerformanceStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

model PerformanceBand {
  id            String @id @default(uuid())
  performanceId String
  bandId        String
  playOrder     Int    @default(0) // 출연 순서 (기획서: required)
  setlist       Json?  // [{"order":1,"song":"..."}] (DB_schema)

  performance Performance @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  band        Band        @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@unique([performanceId, bandId])
  @@map("performance_bands")
}

// ============================================
// 4. Venue (공연장) 관리
// ============================================

model Venue {
  id             String   @id @default(uuid())
  name           String
  address        String
  latitude       Float?   // DB_schema: 위도
  longitude      Float?   // DB_schema: 경도
  phone          String?  // DB_schema: 연락처
  capacity       Int?
  operatingHours Json?    // { "mon": "18:00-24:00", ... } (기획서)
  rentalFee      Json?    // { "weekday": 200000, "weekend": 300000 } (기획서)
  description    String?
  photos         String[] // 공연장 사진 배열
  amenities      String[] // ["parking", "soundSystem", "lighting"] (기획서)
  managerId      String   // FK → User
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  manager      User               @relation("VenueManager", fields: [managerId], references: [id])
  performances Performance[]
  availability VenueAvailability[]
  reservations Reservation[]

  @@index([managerId])
  @@map("venues")
}

model VenueAvailability {
  id      String             @id @default(uuid())
  venueId String
  date    DateTime           @db.Date
  status  AvailabilityStatus @default(AVAILABLE)
  note    String?            // 기획서: 메모

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, date])
  @@map("venue_availability")
}

enum AvailabilityStatus {
  AVAILABLE
  BOOKED
  BLOCKED
}

// ============================================
// 5. Reservation (예약) 관리
// ============================================

model Reservation {
  id           String            @id @default(uuid())
  bandId       String
  venueId      String
  requestedBy  String            // 예약 신청자 (DB_schema: requested_by)
  date         DateTime          @db.Date
  startTime    String            // "14:00" (기획서: required)
  endTime      String            // "18:00" (기획서: required)
  eventType    String            @default("concert") // "concert"/"rehearsal"/"recording" (기획서)
  expectedSize Int?              // 예상 관객/인원 수 (기획서)
  message      String?           // 밴드 측 메시지
  replyMessage String?           // 공연장 측 응답 메시지 (기획서: replyMessage)
  status       ReservationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Relations
  band          Band           @relation(fields: [bandId], references: [id], onDelete: Cascade)
  venue         Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([venueId, status])
  @@index([bandId, createdAt(sort: Desc)])
  @@index([venueId, date])
  @@map("reservations")
}

enum ReservationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ============================================
// 6. Notification (알림) 시스템
// ============================================

model Notification {
  id            String           @id @default(uuid())
  recipientId   String
  type          NotificationType
  title         String
  body          String?
  // Polymorphic reference (DB_schema 방식)
  referenceId   String?          // 연결된 엔티티 ID
  referenceType String?          // "reservation", "announcement", "performance"
  // 하위 호환: 예약 직접 참조
  reservationId String?
  isRead        Boolean          @default(false)
  createdAt     DateTime         @default(now())

  // Relations
  recipient   User         @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([recipientId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

enum NotificationType {
  RESERVATION_APPROVED
  RESERVATION_REJECTED
  RESERVATION_REQUESTED  // 공연장 관리자에게: 새 예약 요청
  VENUE_ANNOUNCEMENT
  SHOW_REMINDER
  ORG_ANNOUNCEMENT       // 조직 공지 알림
}

// ============================================
// 7. Push Subscription (웹 푸시)
// ============================================

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}
